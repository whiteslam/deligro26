# ---------------------------------------------------------------
# Supabase — copy to .env.local and fill from your project's
# Settings → API. .env.local is gitignored (never commit real keys).
# ---------------------------------------------------------------

# Safe to expose to the browser (protected by Row Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# (alias also accepted: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY)

# SERVER ONLY — bypasses RLS. Never prefix with NEXT_PUBLIC_, never ship to
# the client, never commit. Used only for trusted admin/webhook operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# (alias also accepted: SUPABASE_SECRET_KEY)

# Phone OTP (customer login) — Renflair SMS gateway (same as the legacy site).
#
# REQUIRED, both of them, in any environment where anyone signs in:
#
#  OTP_PEPPER is the only secret in the stored code hash. There is no default —
#  the server throws without it, on purpose. Generate one per environment:
#      openssl rand -hex 32
#
#  RENFLAIR_API_KEY sends the actual text. Without it, OTP runs in "dev mode":
#  no SMS is sent and the code is returned on-screen so the flow is testable.
#  That path is fenced off when NODE_ENV=production (the request 503s instead),
#  because handing back the login code for any phone number would be an
#  authentication bypass — but do not rely on that fence: set the key.
OTP_PEPPER=generate-me-openssl-rand-hex-32
# RENFLAIR_API_KEY=your-renflair-api-key

# Push notifications — OneSignal (web push over FCM/APNs). Without these the
# push sender is a silent no-op. APP_ID is public; the REST key is SERVER-ONLY.
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# ONESIGNAL_ANDROID_CHANNEL_ID=optional-android-channel-id

# Payments — Razorpay. KEY_ID is public (ships to checkout); SECRET is server
# only. WEBHOOK_SECRET is created in the Razorpay Dashboard → Webhooks.
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_or_test_key_id
# RAZORPAY_KEY_ID=rzp_live_or_test_key_id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Google Maps — address picker / map. Public (browser) key; restrict it by
# HTTP referrer in the Google Cloud console.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# Distributed rate limit — Upstash Redis or Vercel KV (Storage → Redis/KV).
# Without these, orders API falls back to a per-instance in-memory limiter.
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# (Vercel KV aliases also accepted: KV_REST_API_URL / KV_REST_API_TOKEN)

# QA / IDOR suite (scripts/qa) — never commit real passwords.
# QA_PASSWORD=generate-me-openssl-rand-base64-18
# BASE_URL=http://localhost:3003
# ZAP_TARGET_URL=https://your-staging.example
# STAGING_URL=https://your-staging.example

# Legacy MySQL import (scripts/import-legacy-catalog.ts) — optional:
# LEGACY_DB_JSON=../u231346219_deligro.json
# LEGACY_SHOP_SCOPE=bemetara
# LEGACY_ASSETS_BASE_URL=https://your-old-server.example
# USE_PEXELS_IMAGES=0
# IMPORT_ALL_APPROVED=1
